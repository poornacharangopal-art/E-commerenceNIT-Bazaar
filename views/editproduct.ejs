<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Edit Product</title>

<link rel="stylesheet" href="/css/editproduct.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

</head>

<body>

<div class="container">

<div class="card">

<h1>Edit Product</h1>

<form action="/update/<%= product._id %>" method="POST">

<input
type="text"
name="productName"
value="<%= product.Name %>"
required>

<input
type="text"
name="image"
value="<%= product.ImageUrl %>"
required>

<input
type="number"
name="cost"
value="<%= product.Cost %>"
required>

<select name="category">

<option value="Books"
<%= product.Category==="Books" ? "selected" : "" %>>
Books
</option>

<option value="Electronics"
<%= product.Category==="Electronics" ? "selected" : "" %>>
Electronics
</option>

<option value="Furniture"
<%= product.Category==="Furniture" ? "selected" : "" %>>
Furniture
</option>

<option value="Notes"
<%= product.Category==="Notes" ? "selected" : "" %>>
Notes
</option>

<option value="Others"
<%= product.Category==="Others" ? "selected" : "" %>>
Others
</option>

</select>

<textarea
name="description"
rows="5"><%= product.Description %></textarea>

<button>

Update Product

</button>

<a href="/myproducts">

Cancel

</a>

</form>

</div>

</div>

</body>

</html>
