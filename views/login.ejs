<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Login</title>

    <link rel="stylesheet"
          href="/css/login.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap"
          rel="stylesheet">

</head>

<body>

<div class="container">

<div class="card">

<h1>NIT Bazaar</h1>

<h2>Welcome Back</h2>

<p>Login to continue</p>

<form action="/signin" method="POST">

<input
type="email"
name="email"
placeholder="Email Address"
required>

<input
type="password"
name="password"
placeholder="Password"
required>

<button>

Login

</button>

</form>

<div class="bottom">

<p>

Don't have an account?

<a href="/otp">

Sign Up

</a>

</p>

</div>

</div>

</div>

</body>

</html>
