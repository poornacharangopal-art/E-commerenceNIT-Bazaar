<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Dashboard</title>

<link rel="stylesheet"
href="/css/dashboard.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap"
rel="stylesheet">

</head>

<body>

<nav>

<h2>NIT Bazaar</h2>

<ul>

<li><a href="/dashboard">Home</a></li>

<li><a href="/products">Products</a></li>

<li><a href="/profile">Profile</a></li>

<li><a href="/logout">Logout</a></li>

</ul>

</nav>

<section class="hero">

<h1>

Welcome,

<%= name %> 👋

</h1>

<p>

Buy and Sell products within your college campus.

</p>

</section>

<section class="cards">

<a href="/addproduct" class="card">

<h2>➕</h2>

<h3>Add Product</h3>

<p>

Sell books, gadgets and more.

</p>

</a>

<a href="/products" class="card">

<h2>📦</h2>

<h3>View Products</h3>

<p>

Browse available products.

</p>

</a>

<a href="/profile" class="card">

<h2>👤</h2>

<h3>My Profile</h3>

<p>

View your account details.

</p>

</a>

<a href="/logout" class="card">

<h2>🚪</h2>

<h3>Logout</h3>

<p>

Sign out safely.

</p>

</a>

</section>

<footer>

<p>

© 2026 NIT Bazaar

</p>

</footer>

</body>

</html>
